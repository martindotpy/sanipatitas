{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Sanipatitas",
  "identifier": "dev.martindotpy.sanipatitas",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist/client"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Sanipatitas",
        "width": 800,
        "height": 600,
        "visible": false,
        "hiddenTitle": true,
        "titleBarStyle": "Overlay",
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "wix": {
        "language": "es-ES"
      }
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["sanipatitas"]
      }
    }
  }
}
