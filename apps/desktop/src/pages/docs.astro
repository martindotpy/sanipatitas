---
import Layout from "@sanipatitas/desktop/core/components/layouts/Layout.astro"
import { isProd } from "@sanipatitas/shared/app-context"
import { ScalarComponent } from "@scalar/astro"

// Context
export const prerender = true

// Redirect if the build is in production
if (isProd) {
  return Astro.redirect("/404", 302)
}
---

<Layout
  title="OpenAPI Documentation"
  description="Explore the OpenAPI documentation for all services."
>
  <ScalarComponent
    configuration={{
      theme: "deepSpace",
      sources: [
        {
          title: "Core",
          url: "/api/core/openapi.json",
        },
        {
          title: "Auth",
          url: "/api/auth/openapi.json",
        },
      ],
    }}
  />
</Layout>

<style>
  @reference "@sanipatitas/desktop/styles";

  :root {
    --scalar-font: var(--default-font-family);
  }

  html {
    @apply no-scrollbar;
  }
</style>
