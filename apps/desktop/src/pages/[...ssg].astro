---
import Layout from "@sanipatitas/desktop/core/components/layouts/Layout.astro"
import { isDev } from "@sanipatitas/desktop/core/configuration/app-configuration"
import { AppEntry } from "@sanipatitas/desktop/pages/_app/entry"
import { handleSsrRequest } from "@sanipatitas/desktop/pages/_app/handle-ssr-request"
import type { GetStaticPaths } from "astro"
import type { ComponentProps } from "astro/types"

// Context
type Props = ComponentProps<typeof Layout>

export const prerender = !isDev // Live render in dev

export const getStaticPaths = (() => {
  const routes: string[] = ["/", "/sign-in"]

  return routes.map((ssg) => ({
    params: { ssg },
  }))
}) satisfies GetStaticPaths

// Handle redirect response
const { redirectResponse, getServerRouter, scriptHtml } =
  await handleSsrRequest(Astro)

if (redirectResponse) return redirectResponse

// Page props
const { props } = Astro
---

<Layout {...props}>
  <AppEntry client:load getServerRouter={getServerRouter} />

  <Fragment set:html={scriptHtml} />
</Layout>
