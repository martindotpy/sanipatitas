<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:camunda="http://camunda.org/schema/1.0/bpmn" id="Definitions_AprobacionCitaVeterinaria" targetNamespace="https://sanipatitas.dev/bpmn">
  <bpmn:process id="aprobacion_cita_veterinaria" name="Aprobacion de cita veterinaria" isExecutable="true">
    <bpmn:startEvent id="Start_AppointmentRequested" name="Solicitud de cita">
      <bpmn:outgoing>Flow_Start_CheckAvailability</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:serviceTask id="Task_CheckAvailability" name="Validar disponibilidad" camunda:type="external" camunda:topic="appointment-availability">
      <bpmn:incoming>Flow_Start_CheckAvailability</bpmn:incoming>
      <bpmn:outgoing>Flow_Check_Gateway</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="Gateway_Available" name="Horario disponible?">
      <bpmn:incoming>Flow_Check_Gateway</bpmn:incoming>
      <bpmn:outgoing>Flow_Available_Review</bpmn:outgoing>
      <bpmn:outgoing>Flow_NotAvailable_Reject</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="Task_VetReview" name="Revision del veterinario" camunda:candidateGroups="veterinarian,admin">
      <bpmn:incoming>Flow_Available_Review</bpmn:incoming>
      <bpmn:outgoing>Flow_Review_Decision</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="Gateway_Approved" name="Cita aprobada?">
      <bpmn:incoming>Flow_Review_Decision</bpmn:incoming>
      <bpmn:outgoing>Flow_Approved_Confirm</bpmn:outgoing>
      <bpmn:outgoing>Flow_Rejected_Notify</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="Task_ConfirmAppointment" name="Confirmar cita" camunda:type="external" camunda:topic="appointment-confirm">
      <bpmn:incoming>Flow_Approved_Confirm</bpmn:incoming>
      <bpmn:outgoing>Flow_Confirm_Notify</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Task_NotifyResult" name="Notificar resultado" camunda:type="external" camunda:topic="appointment-notify">
      <bpmn:incoming>Flow_Confirm_Notify</bpmn:incoming>
      <bpmn:incoming>Flow_Rejected_Notify</bpmn:incoming>
      <bpmn:incoming>Flow_NotAvailable_Reject</bpmn:incoming>
      <bpmn:outgoing>Flow_Notify_End</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="End_AppointmentProcessed" name="Cita procesada">
      <bpmn:incoming>Flow_Notify_End</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_Start_CheckAvailability" sourceRef="Start_AppointmentRequested" targetRef="Task_CheckAvailability" />
    <bpmn:sequenceFlow id="Flow_Check_Gateway" sourceRef="Task_CheckAvailability" targetRef="Gateway_Available" />
    <bpmn:sequenceFlow id="Flow_Available_Review" name="Si" sourceRef="Gateway_Available" targetRef="Task_VetReview" />
    <bpmn:sequenceFlow id="Flow_NotAvailable_Reject" name="No" sourceRef="Gateway_Available" targetRef="Task_NotifyResult" />
    <bpmn:sequenceFlow id="Flow_Review_Decision" sourceRef="Task_VetReview" targetRef="Gateway_Approved" />
    <bpmn:sequenceFlow id="Flow_Approved_Confirm" name="Si" sourceRef="Gateway_Approved" targetRef="Task_ConfirmAppointment" />
    <bpmn:sequenceFlow id="Flow_Rejected_Notify" name="No" sourceRef="Gateway_Approved" targetRef="Task_NotifyResult" />
    <bpmn:sequenceFlow id="Flow_Confirm_Notify" sourceRef="Task_ConfirmAppointment" targetRef="Task_NotifyResult" />
    <bpmn:sequenceFlow id="Flow_Notify_End" sourceRef="Task_NotifyResult" targetRef="End_AppointmentProcessed" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_AprobacionCitaVeterinaria">
    <bpmndi:BPMNPlane id="BPMNPlane_AprobacionCitaVeterinaria" bpmnElement="aprobacion_cita_veterinaria">
      <bpmndi:BPMNShape id="Start_AppointmentRequested_di" bpmnElement="Start_AppointmentRequested"><dc:Bounds x="160" y="160" width="36" height="36" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_CheckAvailability_di" bpmnElement="Task_CheckAvailability"><dc:Bounds x="250" y="138" width="150" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_Available_di" bpmnElement="Gateway_Available" isMarkerVisible="true"><dc:Bounds x="455" y="153" width="50" height="50" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_VetReview_di" bpmnElement="Task_VetReview"><dc:Bounds x="560" y="138" width="150" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_Approved_di" bpmnElement="Gateway_Approved" isMarkerVisible="true"><dc:Bounds x="765" y="153" width="50" height="50" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_ConfirmAppointment_di" bpmnElement="Task_ConfirmAppointment"><dc:Bounds x="870" y="138" width="150" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_NotifyResult_di" bpmnElement="Task_NotifyResult"><dc:Bounds x="1080" y="138" width="150" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="End_AppointmentProcessed_di" bpmnElement="End_AppointmentProcessed"><dc:Bounds x="1292" y="160" width="36" height="36" /></bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Flow_Start_CheckAvailability_di" bpmnElement="Flow_Start_CheckAvailability"><di:waypoint x="196" y="178" /><di:waypoint x="250" y="178" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Check_Gateway_di" bpmnElement="Flow_Check_Gateway"><di:waypoint x="400" y="178" /><di:waypoint x="455" y="178" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Available_Review_di" bpmnElement="Flow_Available_Review"><di:waypoint x="505" y="178" /><di:waypoint x="560" y="178" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_NotAvailable_Reject_di" bpmnElement="Flow_NotAvailable_Reject"><di:waypoint x="480" y="203" /><di:waypoint x="480" y="300" /><di:waypoint x="1155" y="300" /><di:waypoint x="1155" y="218" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Review_Decision_di" bpmnElement="Flow_Review_Decision"><di:waypoint x="710" y="178" /><di:waypoint x="765" y="178" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Approved_Confirm_di" bpmnElement="Flow_Approved_Confirm"><di:waypoint x="815" y="178" /><di:waypoint x="870" y="178" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Rejected_Notify_di" bpmnElement="Flow_Rejected_Notify"><di:waypoint x="790" y="203" /><di:waypoint x="790" y="260" /><di:waypoint x="1155" y="260" /><di:waypoint x="1155" y="218" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Confirm_Notify_di" bpmnElement="Flow_Confirm_Notify"><di:waypoint x="1020" y="178" /><di:waypoint x="1080" y="178" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Notify_End_di" bpmnElement="Flow_Notify_End"><di:waypoint x="1230" y="178" /><di:waypoint x="1292" y="178" /></bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
