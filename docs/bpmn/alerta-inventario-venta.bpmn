<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:camunda="http://camunda.org/schema/1.0/bpmn" id="Definitions_AlertaInventarioVenta" targetNamespace="https://sanipatitas.dev/bpmn">
  <bpmn:process id="alerta_inventario_venta" name="Alerta de inventario por venta" isExecutable="true">
    <bpmn:startEvent id="Start_SaleRegistered" name="Venta registrada">
      <bpmn:outgoing>Flow_Start_CheckStock</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:serviceTask id="Task_CheckStock" name="Verificar stock" camunda:type="external" camunda:topic="inventory-check-stock">
      <bpmn:incoming>Flow_Start_CheckStock</bpmn:incoming>
      <bpmn:outgoing>Flow_Check_Gateway</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="Gateway_LowStock" name="Stock bajo?">
      <bpmn:incoming>Flow_Check_Gateway</bpmn:incoming>
      <bpmn:outgoing>Flow_LowStock_CreateTask</bpmn:outgoing>
      <bpmn:outgoing>Flow_StockOk_End</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="Task_CreateReorderAlert" name="Crear alerta de reposicion" camunda:type="external" camunda:topic="inventory-reorder-alert">
      <bpmn:incoming>Flow_LowStock_CreateTask</bpmn:incoming>
      <bpmn:outgoing>Flow_CreateTask_Review</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:userTask id="Task_AdminReview" name="Revision administrativa" camunda:candidateGroups="admin">
      <bpmn:incoming>Flow_CreateTask_Review</bpmn:incoming>
      <bpmn:outgoing>Flow_Review_End</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:endEvent id="End_StockReviewed" name="Inventario evaluado">
      <bpmn:incoming>Flow_StockOk_End</bpmn:incoming>
      <bpmn:incoming>Flow_Review_End</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_Start_CheckStock" sourceRef="Start_SaleRegistered" targetRef="Task_CheckStock" />
    <bpmn:sequenceFlow id="Flow_Check_Gateway" sourceRef="Task_CheckStock" targetRef="Gateway_LowStock" />
    <bpmn:sequenceFlow id="Flow_LowStock_CreateTask" name="Si" sourceRef="Gateway_LowStock" targetRef="Task_CreateReorderAlert" />
    <bpmn:sequenceFlow id="Flow_StockOk_End" name="No" sourceRef="Gateway_LowStock" targetRef="End_StockReviewed" />
    <bpmn:sequenceFlow id="Flow_CreateTask_Review" sourceRef="Task_CreateReorderAlert" targetRef="Task_AdminReview" />
    <bpmn:sequenceFlow id="Flow_Review_End" sourceRef="Task_AdminReview" targetRef="End_StockReviewed" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_AlertaInventarioVenta">
    <bpmndi:BPMNPlane id="BPMNPlane_AlertaInventarioVenta" bpmnElement="alerta_inventario_venta">
      <bpmndi:BPMNShape id="Start_SaleRegistered_di" bpmnElement="Start_SaleRegistered"><dc:Bounds x="160" y="160" width="36" height="36" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_CheckStock_di" bpmnElement="Task_CheckStock"><dc:Bounds x="250" y="138" width="150" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_LowStock_di" bpmnElement="Gateway_LowStock" isMarkerVisible="true"><dc:Bounds x="455" y="153" width="50" height="50" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_CreateReorderAlert_di" bpmnElement="Task_CreateReorderAlert"><dc:Bounds x="560" y="138" width="150" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_AdminReview_di" bpmnElement="Task_AdminReview"><dc:Bounds x="765" y="138" width="150" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="End_StockReviewed_di" bpmnElement="End_StockReviewed"><dc:Bounds x="982" y="160" width="36" height="36" /></bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Flow_Start_CheckStock_di" bpmnElement="Flow_Start_CheckStock"><di:waypoint x="196" y="178" /><di:waypoint x="250" y="178" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Check_Gateway_di" bpmnElement="Flow_Check_Gateway"><di:waypoint x="400" y="178" /><di:waypoint x="455" y="178" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_LowStock_CreateTask_di" bpmnElement="Flow_LowStock_CreateTask"><di:waypoint x="505" y="178" /><di:waypoint x="560" y="178" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_StockOk_End_di" bpmnElement="Flow_StockOk_End"><di:waypoint x="480" y="203" /><di:waypoint x="480" y="280" /><di:waypoint x="1000" y="280" /><di:waypoint x="1000" y="196" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_CreateTask_Review_di" bpmnElement="Flow_CreateTask_Review"><di:waypoint x="710" y="178" /><di:waypoint x="765" y="178" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Review_End_di" bpmnElement="Flow_Review_End"><di:waypoint x="915" y="178" /><di:waypoint x="982" y="178" /></bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
