{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node-terminal",
      "name": "Sanipatitas (desktop) 🐞",
      "request": "launch",
      "command": "bun run tauri dev",
      "cwd": "${workspaceFolder}/apps/desktop",
      "internalConsoleOptions": "neverOpen"
    },
    {
      "type": "bun",
      "name": "Sanipatitas (auth) 🐞",
      "request": "launch",
      "program": "src/index.ts",
      "watchMode": "hot",
      "cwd": "${workspaceFolder}/services/auth",
      "internalConsoleOptions": "neverOpen",
      "preLaunchTask": "patient:dev"
    },
    {
      "type": "java",
      "name": "Sanipatitas (patient) 🐞",
      "request": "attach",
      "preLaunchTask": "patient:dev",
      "hostName": "localhost",
      "port": 5005
    },
    {
      "type": "java",
      "name": "Sanipatitas (appointment) 🐞",
      "request": "attach",
      "preLaunchTask": "appointment:dev",
      "hostName": "localhost",
      "port": 5006
    },
    {
      "type": "node-terminal",
      "name": "Sanipatitas (openapi) 🐞",
      "request": "launch",
      "preLaunchTask": "wait",
      "command": "bun run api:generate",
      "cwd": "${workspaceFolder}/shared/typescript",
      "internalConsoleOptions": "neverOpen"
    },
    {
      "type": "chrome",
      "name": "Sanipatitas (web) 🐞",
      "request": "launch",
      "url": "http://localhost:1420",
      "webRoot": "${workspaceFolder}/apps/desktop"
    }
  ],
  "compounds": [
    {
      "name": "Sanipatitas 🐞",
      "configurations": [
        "Sanipatitas (auth) 🐞",
        "Sanipatitas (patient) 🐞",
        "Sanipatitas (appointment) 🐞",
        "Sanipatitas (desktop) 🐞"
      ],
      "stopAll": true,
      "preLaunchTask": "patient:dev"
    }
  ]
}
