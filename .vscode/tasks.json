// See https://go.microsoft.com/fwlink/?LinkId=733558
// for the documentation about the tasks.json format
{
  "version": "2.0.0",
  "tasks": [
    {
      "type": "shell",
      "group": "build",
      "label": "patient:dev",
      "isBackground": true,
      "problemMatcher": [
        {
          "pattern": [
            {
              "regexp": "\\[(\\d+)\\]\\s(.*):(\\d+):(\\d+)\\s\\-\\s{(.*)}:\\s(.*)$",
              "file": 2,
              "line": 3,
              "column": 4,
              "message": 6
            }
          ],
          "background": {
            "activeOnStart": true,
            "beginsPattern": "^.*Scanning for projects...",
            "endsPattern": "(^.*Quarkus .* started in .*\\.)|(^.* ERROR .* Failed to start)"
          }
        }
      ],
      "command": "./mvnw",
      "windows": {
        "command": ".\\mvnw.cmd"
      },
      "args": ["-f", "services/patient/pom.xml", "quarkus:dev"]
    },
    {
      "type": "shell",
      "group": "build",
      "label": "appointment:dev",
      "isBackground": true,
      "problemMatcher": [
        {
          "pattern": [
            {
              "regexp": "\\[(\\d+)\\]\\s(.*):(\\d+):(\\d+)\\s\\-\\s{(.*)}:\\s(.*)$",
              "file": 2,
              "line": 3,
              "column": 4,
              "message": 6
            }
          ],
          "background": {
            "activeOnStart": true,
            "beginsPattern": "^.*Scanning for projects...",
            "endsPattern": "(^.*Quarkus .* started in .*\\.)|(^.* ERROR .* Failed to start)"
          }
        }
      ],
      "command": "./mvnw",
      "windows": {
        "command": ".\\mvnw.cmd"
      },
      "args": ["-f", "services/appointment/pom.xml", "quarkus:dev"]
    },
    {
      "type": "shell",
      "label": "wait",
      "command": "sleep 90",
      "windows": {
        "command": "timeout /t 90"
      }
    }
  ]
}
